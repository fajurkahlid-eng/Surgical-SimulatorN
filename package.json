{
  "name": "surgical-training-vr",
  "version": "1.0.0",
  "description": "Surgical Training Environment VR",
  "type": "module",
  "author": "Fajr Khalid Mohammed Almuwallad",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run server\" \"vite\"",
    "dev:web": "vite",
    "dev:all": "npm run dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "server": "cd server && npm run dev",
    "server:start": "cd server && npm start"
  },
  "dependencies": {
    "mermaid": "^11.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^7.3.5"
  }
}
